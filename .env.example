# Maven Central (Central Portal) publishing credentials.
# Copy to `.env` (gitignored) and fill in. Used by `task publish:central`.

# Central Portal user token — central.sonatype.com -> Account -> Generate User Token
CENTRAL_USERNAME=
CENTRAL_PASSWORD=

# GPG signing. The armored secret key lives in a file (multi-line); point to it.
# Passphrase is empty for an unprotected key — leave blank.
SIGNING_KEY_FILE=.seckey
SIGNING_PASSWORD=

# npm publish (automation token bypasses the org 2FA OTP prompt)
NPM_DEEMWAR_IO_PUBLISH_TOKEN=
